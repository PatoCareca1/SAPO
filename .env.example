# Copie este arquivo para .env e ajuste os valores localmente.
# Nunca commitar o .env real (ja esta no .gitignore).

# String de conexao do PostgreSQL.
# Dev local (combina com o docker-compose.yml): use o valor abaixo.
# Homolog (Supabase/Neon): substitua pela connection string da plataforma.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sapo?schema=public"

# Homolog com Supabase usando pooler (pgbouncer): defina TAMBEM a conexao direta
# para as migrations (Prisma nao roda migrate pelo pooler). Descomente se usar:
# DIRECT_URL="postgresql://postgres:senha@db.xxx.supabase.co:5432/postgres"

# Auth.js — gerar com `npx auth secret` ou `openssl rand -base64 33`.
AUTH_SECRET=""

# Credenciais OAuth do Google Cloud Console.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Dominios institucionais aceitos (separados por virgula).
# Subdominios sao aceitos automaticamente (ex.: academico.ufrn.edu.br).
ALLOWED_EMAIL_DOMAINS="ufrn.edu.br,ufrn.br"

# E-mails que devem entrar como professor (role PROFESSOR), separados por virgula.
PROFESSOR_EMAILS=""
